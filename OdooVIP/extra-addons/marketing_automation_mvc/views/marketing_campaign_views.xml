<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_marketing_campaign_form" model="ir.ui.view">
        <field name="name">mvc.marketing.campaign.form</field>
        <field name="model">mvc.marketing.campaign</field>
        <field name="arch" type="xml">
            <form string="Marketing Campaign">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,running,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_marketing_participant)d" type="action" class="oe_stat_button" icon="fa-users" context="{'search_default_campaign_id': id, 'default_campaign_id': id}">
                            <field name="total_participants" widget="statinfo" string="Participants"/>
                        </button>
                        <button name="%(action_marketing_activity)d" type="action" class="oe_stat_button" icon="fa-cogs" context="{'search_default_campaign_id': id, 'default_campaign_id': id}">
                            <span class="o_stat_text">Activities</span>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Summer Sale 2026"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Activities" name="activities">
                            <field name="activity_ids" context="{'default_campaign_id': id}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="activity_type"/>
                                    <field name="trigger_type"/>
                                    <field name="delay_count"/>
                                    <field name="delay_unit"/>
                                </list>
                            </field>
                        </page>
                        <page string="Participants" name="participants">
                            <field name="participant_ids" context="{'default_campaign_id': id}" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Campaign details..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View (replaces Tree in v19+) -->
    <record id="view_marketing_campaign_list" model="ir.ui.view">
        <field name="name">mvc.marketing.campaign.list</field>
        <field name="model">mvc.marketing.campaign</field>
        <field name="arch" type="xml">
            <list string="Marketing Campaigns">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_participants"/>
                <field name="success_rate" widget="progressbar"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'running'" decoration-muted="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_marketing_campaign_search" model="ir.ui.view">
        <field name="name">mvc.marketing.campaign.search</field>
        <field name="model">mvc.marketing.campaign</field>
        <field name="arch" type="xml">
            <search string="Search Campaigns">
                <field name="name"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_marketing_campaign" model="ir.actions.act_window">
        <field name="name">Campaigns</field>
        <field name="res_model">mvc.marketing.campaign</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Marketing Campaign
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_marketing_automation_root" name="Marketing MVC" sequence="100"/>
    <menuitem id="menu_marketing_campaign" name="Campaigns" parent="menu_marketing_automation_root" action="action_marketing_campaign" sequence="10"/>

</odoo>
