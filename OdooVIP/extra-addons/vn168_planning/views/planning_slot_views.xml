<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_planning_slot_form" model="ir.ui.view">
        <field name="name">planning.slot.form</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" string="Publish" type="object" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_planning_slot_list" model="ir.ui.view">
        <field name="name">planning.slot.list</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <list>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_planning_slot" model="ir.actions.act_window">
        <field name="name">Schedule</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
