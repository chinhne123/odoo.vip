<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VN168 Branding: Favicon, Title, Login Logo -->
    <template id="web_layout_branding" inherit_id="web.layout">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link type="image/png" rel="icon" href="/vn168_theme/static/src/img/logo.png?v=2"/>
            <link type="image/png" rel="shortcut icon" href="/vn168_theme/static/src/img/logo.png?v=2"/>
        </xpath>
        <xpath expr="//title" position="replace">
            <title>VN168 Enterprise</title>
        </xpath>
    </template>

    <template id="login_layout_branding" inherit_id="web.login_layout">
        <xpath expr="//div[hasclass('text-center')]/img" position="replace">
            <img src="/vn168_theme/static/src/img/logo.png" alt="VN168 Logo" style="max-height:120px;"/>
        </xpath>
    </template>

    <!-- JS Tự động đổi tên Odoo thành VN168 trên Navbar -->
    <template id="web_layout_branding_script" inherit_id="web.layout">
        <xpath expr="//head" position="inside">
            <script type="text/javascript">
                (function () {
                    'use strict';
                    setInterval(function() {
                        var brand = document.querySelector('.o_menu_brand');
                        if (brand &amp;&amp; brand.innerText === 'Odoo') brand.innerText = 'VN168';
                    }, 1000);
                })();
            </script>
        </xpath>
    </template>
</odoo>
