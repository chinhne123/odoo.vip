<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VN168 Branding: Favicon, Title, Login Logo -->
    <template id="web_layout_branding" inherit_id="web.layout">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link type="image/png" rel="icon" href="/vn168_theme/static/src/img/favicon.png?v=4"/>
            <link type="image/x-icon" rel="shortcut icon" href="/vn168_theme/static/src/img/favicon.ico?v=4"/>
        </xpath>
        <xpath expr="//title" position="replace">
            <title>VN168 Enterprise</title>
        </xpath>
    </template>

    <template id="login_layout_branding" inherit_id="web.login_layout" priority="99">
        <xpath expr="//div[hasclass('oe_website_login_container')]" position="replace">
            <div class="oe_website_login_container container-custom-login">
                <style>
                    /* CUSTOM LOGIN LAYOUT STYLES - FULL WDITH */
                    .container-custom-login { display: flex; align-items: stretch; justify-content: center; min-height: calc(100vh - 200px); padding: 0 !important; margin: 0 !important; max-width: 100vw; overflow-x: hidden; }
                    .custom-login-card { display: flex; flex-direction: row; width: 100%; max-width: 100%; background: transparent; border-radius: 0; box-shadow: none; overflow: hidden; margin: 0; }
                    .custom-login-left { width: 40%; min-width: 320px; max-width: 600px; background: #ffffff; padding: 4rem 8%; display: flex; flex-direction: column; justify-content: center; align-items: center; position: relative; border-radius: 0; z-index: 2; flex: 1 1 auto; }
                    .custom-login-right { width: 60%; background: linear-gradient(135deg, #2b4c80 0%, #172852 100%); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; border-radius: 0; flex: 1 1 60%;}
                    
                    /* Background Abstract Shapes */
                    .wavy-bg { position: absolute; width: 100%; height: 100%; top: 0; left: 0; z-index: 1; opacity: 0.8; }
                    .wavy-blob-1 { position: absolute; width: 350px; height: 350px; background: linear-gradient(180deg, #eaddc5 0%, rgba(234, 221, 197, 0) 100%); border-radius: 50%; top: -50px; left: -100px; filter: blur(40px); opacity: 0.6; mix-blend-mode: color-dodge;}
                    .wavy-blob-2 { position: absolute; width: 450px; height: 450px; background: linear-gradient(180deg, #93b9d6 0%, rgba(147, 185, 214, 0) 100%); border-radius: 50%; bottom: -150px; right: -50px; filter: blur(50px); opacity: 0.5; mix-blend-mode: screen;}
                    .wavy-blob-3 { position: absolute; width: 250px; height: 250px; background: #fdf5e6; border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%, -50%); filter: blur(80px); opacity: 0.3;}
                    
                    .right-text-content { z-index: 2; color: #fff; padding: 3rem; width: 100%; max-width: 900px; text-align: left; margin: 0 auto; }
                    .right-text-content h2 { font-size: clamp(2.5rem, 5vw, 4.5rem); }
                    .right-text-content p { font-size: clamp(0.9rem, 1.5vw, 1.1rem); }

                    /* Left Side / Form adjustments */
                    .custom-login-left-wrapper { width: 100%; max-width: 450px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
                    .login-logo-container { position: absolute; top: 30px; left: 40px; }
                    .login-logo-container img { max-height: clamp(50px, 8vw, 80px); max-width: 100%; object-fit: contain; }
                    
                    .login-icon-avatar { width: 80px; height: 80px; background: #1f3660; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 2rem; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
                    .custom-login-left .mb-3.field-login input, .custom-login-left .input-group input { border-radius: 30px !important; padding-left: 45px; border: 2px solid #333; height: 48px; border-color: #333 !important; outline: none; box-shadow: none !important;}
                    .custom-login-left .input-group { border-radius: 30px !important; overflow: hidden; border: 2px solid #333;}
                    .custom-login-left .input-group input { border: none !important; height: 44px; padding-left: 45px; }
                    .custom-login-left .input-group .btn { border: none !important; background: transparent; color: #333; display: flex; align-items: center; padding-right: 15px; }
                    
                    .custom-login-left .btn-primary { border-radius: 30px !important; background: #1f3660 !important; border: none !important; padding: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; width: 100%; margin-top: 10px; box-shadow: 0 4px 12px rgba(31,54,96,0.3) !important; transition: all 0.3s ease; }
                    .custom-login-left .btn-primary:hover { background: #122240 !important; transform: translateY(-2px); box-shadow: 0 6px 16px rgba(31,54,96,0.4) !important;}

                    .custom-login-left .form-label { display: none !important; }
                    .custom-login-left .o_caps_lock_warning a.btn-link { display: none !important; }
                    
                    /* Form Inputs Icons Injection */
                    .custom-login-left .field-login { position: relative; }
                    .custom-login-left .field-login::before { content: "\f007"; font-family: FontAwesome; position: absolute; left: 18px; top: 14px; font-size: 16px; color: #555; z-index: 10; pointer-events: none;}
                    .custom-login-left .o_caps_lock_warning { position: relative; }
                    .custom-login-left .o_caps_lock_warning::before { content: "\f023"; font-family: FontAwesome; position: absolute; left: 18px; top: 14px; font-size: 16px; color: #555; z-index: 10; pointer-events: none;}
                    
                    @media (max-width: 991.98px) {
                        .custom-login-card { flex-direction: column; }
                        .custom-login-left { width: 100%; min-width: 100%; max-width: 100%; padding: 4rem 5%; flex: block; align-items: center; }
                        .custom-login-right { width: 100%; flex: block; min-height: 400px; }
                        .login-logo-container { position: relative; top: 0; left: 0; margin-bottom: 2rem; }
                    }
                    @media (max-width: 575.98px) {
                        .custom-login-right { display: none !important; }
                        .custom-login-left { padding: 3rem 1.5rem; }
                        .right-text-content { padding: 2rem; }
                        .container-custom-login { min-height: calc(100vh - 120px); }
                    }
                </style>
                <div class="custom-login-card mx-auto">
                    <!-- Left Column (Form) -->
                    <div class="custom-login-left">
                        <div class="custom-login-left-wrapper">
                        <!--
                        <div class="login-logo-container">
                            <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}" alt="Logo"/>
                        </div>
                        -->
                        
                        <div class="login-icon-avatar">
                            <i class="fa fa-user-o"></i>
                        </div>
                        
                        <div class="w-100">
                            <!-- Render the Odoo login form components here directly -->
                            <t t-out="0"/>
                        </div>
                        
                        <div class="text-center small mt-4 pt-3 border-top w-100" t-if="not disable_footer and not disable_database_manager">
                            <a class="text-muted text-decoration-none fw-bold" href="/web/database/manager">Manage Databases <i class="fa fa-database ms-1"></i></a>
                        </div>
                        </div>
                    </div>
                    
                    <!-- Right Column (Image/Decoration) -->
                    <div class="custom-login-right">
                        <div class="wavy-bg">
                            <div class="wavy-blob-1"></div>
                            <div class="wavy-blob-2"></div>
                            <div class="wavy-blob-3"></div>
                        </div>
                        <div class="right-text-content position-relative">
                            <h2 class="display-3 fw-bold mb-3" style="letter-spacing: -1px;">Welcome.</h2>
                            <p class="fs-6 opacity-75 pe-md-5" style="line-height: 1.6;">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed diam nonummy nibh euismod tincidunt ut labore et dolore magna aliquam erat volutpat.</p>
                            <!-- <div class="mt-4 pt-4 opacity-75" style="border-top: 1px solid rgba(255,255,255,0.2);">
                                <small>Not a member? <a href="#" class="text-white fw-bold text-decoration-none">Sign up now</a></small>
                            </div> -->
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
    
    <template id="custom_login_form_layout" inherit_id="web.login">
        <!-- Customize Email Placeholder -->
        <xpath expr="//input[@name='login']" position="attributes">
            <attribute name="placeholder">USERNAME</attribute>
        </xpath>
        <!-- Customize Password Placeholder -->
        <xpath expr="//input[@name='password']" position="attributes">
            <attribute name="placeholder">.................</attribute>
        </xpath>
        <!-- Change Login button label safely -->
        <xpath expr="//button[@type='submit']" position="replace">
            <button type="submit" class="btn btn-primary w-100">LOGIN</button>
        </xpath>
        <!-- Insert Remember me and Forgot password before the buttons row -->
        <xpath expr="//div[hasclass('oe_login_buttons')]" position="before">
            <div class="d-flex justify-content-between align-items-center mb-4 px-2" style="font-size: 12px; color: #555;">
                <label class="d-flex align-items-center mb-0" style="cursor: pointer; display: flex !important;">
                    <input type="checkbox" class="me-2" style="accent-color: #333; width: 14px; height: 14px;"/> Remember me
                </label>
                <a href="/web/reset_password" class="text-decoration-none fw-bold" style="color: #555;">Forgot your password?</a>
            </div>
        </xpath>
    </template>

    <!-- JS Tự động đổi tên Odoo thành VN168 trên Navbar -->
    <template id="web_layout_branding_script" inherit_id="web.layout">
        <xpath expr="//head" position="inside">
            <style>
                /* Force any Odoo branding image to preserve VN168 aspect ratio and increase size */
                .o_main_navbar .o_menu_brand img,
                .o_header_standard img,
                .navbar-brand img,
                img.o_company_logo,
                img[src*="logo"],
                img[src*="company_logo"],
                img[src*="odoo-icon"],
                img[src*="odoo_logo"],
                .img-fluid[src*="logo"],
                .o_main_navbar img,
                .o_menu_brand img {
                    max-height: 90px !important;
                    height: 60px !important;
                    width: auto !important;
                    max-width: none !important;
                    object-fit: contain !important;
                }
                .navbar-brand.logo {
                    max-width: none !important;
                    display: flex;
                    align-items: center;
                }
                .navbar-brand.logo span {
                    display: flex;
                    align-items: center;
                }
            </style>
            <script type="text/javascript">
                (function () {
                    'use strict';
                    setInterval(function() {
                        var brand = document.querySelector('.o_menu_brand');
                        if (brand &amp;&amp; brand.innerText === 'Odoo') brand.innerText = 'VN168';
                    }, 1000);
                })();
            </script>
        </xpath>
    </template>
</odoo>
