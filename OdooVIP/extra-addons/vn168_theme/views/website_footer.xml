<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="vn168_custom_footer" inherit_id="website.layout" name="VN168 Custom Footer">
        <xpath expr="//footer[@id='bottom']" position="replace">
            <footer id="bottom" class="vn168-footer bg-light pt-5 pb-3 border-top">
