                            </ul>
                        </div>

                        <!-- Cột 4: Liên hệ -->
                        <div class="col-lg-3 col-md-4 mb-4 footer-text">
                            <h5>Liên hệ</h5>
                            <p class="mb-2">
                                <i class="fa fa-envelope-o text-primary mr-2"></i> <strong>Email</strong><br/>
                                <a href="mailto:vienchuyendoisoquocgia@aivn168.com">vienchuyendoisoquocgia@aivn168.com</a>
                            </p>
                            <p class="mb-2">
                                <i class="fa fa-phone text-primary mr-2"></i> <strong>Điện thoại</strong><br/>
                                <a href="tel:0931454647">0931454647</a>
                            </p>
                            <p class="mb-2">
                                <i class="fa fa-globe text-primary mr-2"></i> <strong>Website giới thiệu</strong><br/>
                                <a href="https://vn168.vn" target="_blank">vn168.vn</a>
                            </p>
                            <p class="mb-0">
                                <i class="fa fa-map-marker text-primary mr-2"></i> <strong>Địa chỉ</strong><br/>
                                31 Nguyễn Nhạc, Phường Buôn Ma Thuột,<br/>
                                Tỉnh Đăk Lăk, Việt Nam
                            </p>
                        </div>
                    </div>

                    <!-- Bottom Bar -->
                    <div class="row bottom-bar align-items-center">
                        <div class="col-md-6 text-center text-md-left mb-2 mb-md-0">
                            © 2024 Nền tảng AI168. Đã đăng ký Bản quyền.
                        </div>
                        <div class="col-md-6 text-center text-md-right bottom-links">
                            <a href="#">Pháp lý</a> •
                            <a href="#">Chính sách bảo mật</a> •
                            <a href="#">Điều khoản sử dụng</a> •
                            <a href="#">Chính sách cookie</a> •
                            <a href="#">Chính sách thanh toán</a> •
                            <a href="#">Bảo mật</a>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>
